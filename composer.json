{
    "name": "thomasmeschke/properties-existence-validator",
    "type": "library",
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpunit/phpunit": "^13.1"
    },
    "scripts": {
        "stan": "phpstan analyze -c phpstan.neon.dist",
        "format": "php-cs-fixer fix"
    },
    "license": "CC0-1.0",
    "autoload": {
        "psr-4": {
            "thomasmeschke\\PropertiesExistenceValidator\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Thomas Meschke",
            "email": "thomas.meschke@gmail.com"
        }
    ],
    "require": {},
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "audit": {
            "abandoned": "report"
        }
    }
}
